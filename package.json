{
  "name": "e2e-playwright-automation-framework",
  "version": "1.0.0",
  "description": "E2E Playwright Automation Framework for DemoQA using Playwright, Cucumber, TypeScript, and Page Object Model.",
  "main": "index.js",
  "scripts": {
    "clean": "node scripts/clean-reports.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run clean && cucumber-js",
    "test:auth": "cucumber-js --tags \"@auth\"",
    "test:bookstore": "cucumber-js --tags \"@bookstore\"",
    "test:api": "cucumber-js --tags \"@api\"",
    "test:api:report": "cucumber-js --tags \"@api\"",
    "test:api:no-report": "cross-env NO_REPORT=true cucumber-js --tags \"@api\"",
    "test:book-store-application": "cucumber-js --tags \"@book-store-application\"",
    "test:forms": "cucumber-js --tags \"@forms\"",
    "test:frames": "cucumber-js --tags \"@frames\"",
    "test:alerts": "cucumber-js --tags \"@alerts\"",
    "test:alerts-frame-windows": "cucumber-js --tags \"@alerts-frame-windows\"",
    "test:nested-frames": "cucumber-js --tags \"@nested-frames\"",
    "test:elements": "cucumber-js --tags \"@elements\"",
    "test:widgets": "cucumber-js --tags \"@widgets\"",
    "test:interactions": "cucumber-js --tags \"@interactions\"",
    "test:modal-dialogs": "cucumber-js --tags \"@modal-dialogs\"",
    "test:auth:report": "cucumber-js --tags \"@auth\"",
    "test:bookstore:report": "cucumber-js --tags \"@bookstore\"",
    "test:forms:report": "cucumber-js --tags \"@forms\"",
    "test:single": "npm run clean && cucumber-js --tags @single",
    "test:parallel": "npm run clean && cucumber-js --tags @parallel",
    "test:mobile": "npm run clean && cross-env DEVICE=mobile cucumber-js",
    "test:desktop": "npm run clean && cross-env DEVICE=desktop cucumber-js",
    "runner": "node runner.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ducyen0811/E2E-PW.git"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "typescript",
    "e2e",
    "demoqa"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ducyen0811/E2E-PW/issues"
  },
  "homepage": "https://github.com/ducyen0811/E2E-PW#readme",
  "dependencies": {
    "@cucumber/cucumber": "^12.5.0",
    "@playwright/test": "^1.57.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "cucumber-html-reporter": "^7.2.0"
  }
}
